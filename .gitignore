
# Ignore node_modules and build folders anywhere in the project
**/node_modules/
**/build/

# Ignore environment and log files
.env
.DS_Store
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Backend runtime logs (rotate daily, may contain request/query data)
backend/logs/
backend/backend_run_output.txt
backend/server.log
backend_run.log
backend_pid.txt
backend/stdout.log
backend/stderr.log

# POS terminal installer build output (produced by electron-builder, not source)
backend/public/downloads/
